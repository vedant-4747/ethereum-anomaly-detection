# ── Ethereum RPC ────────────────────────────────────────────────────
# Get a free URL from https://www.alchemy.com/ or https://infura.io/
ETH_RPC_URL=https://cloudflare-eth.com

# ── PostgreSQL (Supabase / any PostgreSQL host) ──────────────────────
# Create a free project at https://supabase.com, then copy the
# "Connection String" from Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# ── Detection Thresholds ─────────────────────────────────────────────
HIGH_VALUE_THRESHOLD=10
HIGH_GAS_PRICE_THRESHOLD=100
